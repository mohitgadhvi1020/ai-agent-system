# LLM provider: "claude", "openai", or "none" (heuristic demo mode, no key needed)
LLM_PROVIDER=none

# API keys (only required if LLM_PROVIDER is claude/openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Agent behavior
MAX_AGENT_STEPS=10
MAX_MEMORY_TURNS=20

# Server
HOST=0.0.0.0
PORT=8000
